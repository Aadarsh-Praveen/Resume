# ── Anthropic (Claude API) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then get your chat_id by messaging
# the bot and visiting: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# ── Apollo.io (recruiter finder) ────────────────────────────────────────────
# Sign up at apollo.io, go to Settings → Integrations → API → Create API Key
APOLLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion tracker ──────────────────────────────────────────────────────────
# 1. Create an integration: https://www.notion.so/profile/integrations
#    → "New integration" → copy the API key below
# 2. Create a database in Notion with these properties (exact names matter):
#      Name (Title) | Company (Text) | JD URL (URL) | Email (Email)
#      Date (Date)  | Resume File (Text) | ATS Score (Number)
#      Status (Select: ready / low_ats / high_ats / failed) | Notes (Text)
# 3. Open the database → "..." → "Connect to" → select your integration
# 4. Copy the database ID from the URL:
#      notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gmail API (LinkedIn alert parsing) ──────────────────────────────────────
# Enable Gmail API in Google Cloud Console
# Create OAuth2 credentials (Desktop App), download as credentials.json
GMAIL_CREDENTIALS_PATH=/path/to/gmail-credentials.json
GMAIL_TOKEN_PATH=/path/to/gmail-token.json

# ── Application email (used in Notion tracker) ──────────────────────────────
APPLICANT_EMAIL=your.email@gmail.com
APPLICANT_NAME=Your Name

# ── Paths ────────────────────────────────────────────────────────────────────
BASE_RESUME_PATH=base_resume.tex
RESUMES_DIR=resumes
DB_PATH=db/jobs.db
