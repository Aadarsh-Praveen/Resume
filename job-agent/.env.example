# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Hunter.io (recruiter email lookup) ───────────────────────────────────────
HUNTER_API_KEY=

# ── Gmail (LinkedIn alert emails) ────────────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials.json

# ── Google Sheets (optional application log) ─────────────────────────────────
SHEETS_CREDENTIALS_JSON=
SHEETS_SPREADSHEET_ID=

# ── Applicant profile (shown in dashboard + used in cold emails) ──────────────
APPLICANT_NAME=Your Name
APPLICANT_EMAIL=you@email.com
APPLICANT_ROLE=Data Scientist
APPLICANT_LOCATION=San Francisco, CA
APPLICANT_PHONE=+1 (555) 000-0000
APPLICANT_LINKEDIN=https://linkedin.com/in/yourhandle
APPLICANT_GITHUB=https://github.com/yourhandle

# ── GitHub Actions runner (optional — needed for dashboard Run button) ────────
GITHUB_DASHBOARD_TOKEN=
GITHUB_REPO=yourhandle/resume

# ── Paths ─────────────────────────────────────────────────────────────────────
DB_PATH=db/jobs.db
RESUMES_DIR=resumes
